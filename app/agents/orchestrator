class AgentOrchestrator:
    def __init__(self):
        self.planner = PlannerAgent()
        self.tools = {
            "lookup_transaction": TransactionLookupTool(),
        }

    def execute(self, user_input: str, transaction_id: str):
        plan = self.planner.plan(user_input, transaction_id)

        if plan["action"] == "none":
            return plan

        tool = self.tools.get(plan["action"])
        args = json.loads(plan["arguments"])

        result = tool.execute(args)

        return {
            "analysis": plan["analysis"],
            "tool_result": result,
            "confidence": plan["confidence"],
        }