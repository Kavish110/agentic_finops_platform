class PlannerAgent:
    def __init__(self):
        self.llm = OpenAILLM()

    def plan(self, user_input: str, transaction_id: str):
        db = SessionLocal()
        retriever = VectorRetriever(db)

        policies = retriever.retrieve(user_input, limit=3)

        system_prompt = f"""
You are a financial risk agent.
Use the following compliance policies:
{policies}
"""

        return self.llm.generate(
            system_prompt=system_prompt,
            user_prompt=f"{user_input} for transaction {transaction_id}",
        )